# Server
PORT=3000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=rakiestore

# Auth
JWT_SECRET=change_me

# CORS
# - If unset, the API allows all origins (no credentials/cookies).
# - If you need cookies/credentials, set BOTH `CORS_ORIGINS` and `CORS_CREDENTIALS=true`.
# CORS_ORIGINS=http://localhost:5173,http://localhost:3001
# CORS_CREDENTIALS=true
# CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# CORS_HEADERS=Content-Type, Authorization
# CORS_EXPOSE_HEADERS=
# CORS_MAX_AGE=600

# Cloudinary Configuration (for image uploads)
# Sign up at https://cloudinary.com/users/register/free
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Plasgate SMS Configuration
PLASGATE_PRIVATE_KEY=your_private_key
PLASGATE_SECRET=your_secret
PLASGATE_SENDER=SMS_Info

